# Frappe LMS backend
VITE_FRAPPE_URL="https://lms-dzr-tbs.c.frappe.cloud"

# Proxy — relative path works on Vercel (both prod and vercel dev)
VITE_PROXY_URL="/api/proxy"

# Paystack Live public key
VITE_PAYSTACK_PUBLIC_KEY="pk_live_..."

# --- Vercel environment variables (NOT in this file) ---
# Set these in Vercel Dashboard → Settings → Environment Variables:
#   FRAPPE_URL=https://lms-dzr-tbs.c.frappe.cloud
#   FRAPPE_API_KEY=your_frappe_api_key
#   FRAPPE_API_SECRET=your_frappe_api_secret
#   PROXY_JWT_SECRET=your_32_char_random_secret
